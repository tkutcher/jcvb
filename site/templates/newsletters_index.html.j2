{% extends "base.html.j2" %}
{% import "partials/macros.j2" as brand %}
{% block title %}Newsletters · {{ site.short_name }}{% endblock %}
{% block description %}The John Carroll Boys Volleyball newsletter archive — weekly updates, recaps, and program news.{% endblock %}

{% block content %}
<section class="page-hero page-hero--photo">
  <img class="page-hero__photo" src="{{ base }}/assets/pics/team-line.jpg" alt="" aria-hidden="true">
  <div class="container">
    <div class="page-hero__watermark">{{ brand.swirl('newswm') }}</div>
    <span class="eyebrow">Program Communication</span>
    <h1>Newsletters</h1>
    <p>Weekly updates during the season, monthly in the offseason — recaps, results, schedules, and everything Patriots families need to know.</p>
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    {% for year, items in (newsletters|groupby('year'))|reverse %}
    <h2 class="news-year">{{ year }}</h2>
    <div class="news-grid">
      {% for n in items %}
      <a class="news-card" href="{{ base }}/newsletters/{{ n.slug }}/" data-reveal data-reveal-delay="{{ loop.index0 % 4 }}">
        <span class="date">{{ n.weekday }} · Newsletter</span>
        <h3>{{ n.date_long }}</h3>
        <p>{{ n.summary }}</p>
        <span class="go">Read update <span class="arrow">→</span></span>
      </a>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</section>
{% endblock %}
