# Copy to .env (gitignored) and fill in real values. Never commit secrets.

# SendGrid — newsletter distribution (src/jcvb/newsletter.py)
ANVILOR_SG_API_KEY=REPLACE_ME

# Azure service principal — site deploys (scripts/deploy.sh)
JCVB_SITE_MGR_SP_TENANT_ID=REPLACE_ME
JCVB_SITE_MGR_SP_CLIENT_ID=REPLACE_ME
JCVB_SITE_MGR_SP_PASSWORD=REPLACE_ME

# Anvilor API — forms publishing (src/jcvb/forms.py)
# Provision an API key + org OID from the Anvilor portal for the JCVB org.
ANVILOR_API_KEY=REPLACE_ME
ANVILOR_ORG_OID=REPLACE_ME
